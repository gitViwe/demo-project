<MudButton ButtonType="@ButtonType"
           Variant="@Variant"
           Color="@Color"
           Size="@Size"
           Disabled="@Disabled"
           FullWidth="@FullWidth"
           OnClick="@OnClick">
    @if (Loading)
    {
        @if (LoadingContent is not null)
        {
            @LoadingContent
        }
        else
        {
            <MudProgressCircular Class="ms-n1"
                                 Size="Size.Small"
                                 Indeterminate="true" />
            <MudText Class="ms-2">@LoadingMessage</MudText>
        }
    }
    else
    {
        @ChildContent
    }
</MudButton>